# Copie para .env na raiz de signacon-crm/ (docker compose e ferramentas leem daqui).
# Nunca commite .env com segredos reais.

# --- PostgreSQL (Docker Compose — Story 0.2) ---
POSTGRES_USER=signacon
POSTGRES_PASSWORD=signacon_dev
POSTGRES_DB=signacon_crm
POSTGRES_PORT=5432

# Deve refletir user/password/db/port acima (Prisma — Story 0.3).
DATABASE_URL=postgresql://signacon:signacon_dev@localhost:5432/signacon_crm?schema=public

# --- API (Stories 0.4+) ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Auth / JWT (Story 1.1+) — mínimo 32 caracteres ---
# Nota: evita `$` no valor sem aspas — o loader pode expandir e o segredo fica inválido.
JWT_SECRET=dev-signacon-jwt-secret-minimum-32-characters-long-ok
JWT_ACCESS_EXPIRES_SEC=900
REFRESH_TOKEN_EXPIRES_DAYS=7

# --- Seed (dev) — obrigatório para `pnpm db:seed` ---
SEED_ADMIN_PASSWORD=2@nQ8*yP

# --- WhatsApp Cloud API (Epic 2 / Story 2.1+) ---
# Usado na verificação do webhook (GET /whatsapp/webhook com hub.*).
WHATSAPP_VERIFY_TOKEN=hEVui8AD68RcHZkiT9XVBEAoQS64xXepHoWUmPkqaDZlXbkEPTROKgIevpiTUFm6

# Segredo da app Meta (usado para validar assinatura X-Hub-Signature-256 no POST do webhook).
WHATSAPP_APP_SECRET=7cf09b24785f503b0ef5c2a29e1dc23a

# Opcional (futuro / Story 8.5): IDs de phone_number_id permitidos, separados por vírgula,
# para ignorar eventos de outros números quando houver vários na mesma app Meta.
# ALLOWED_PHONE_NUMBER_IDS=123456789012345,987654321098765

# Epic 6.5: ao concluir uma task com conversa vinculada, marcar a conversa como respondida (unanswered=false).
# TASK_DONE_SETS_CONVERSATION_ANSWERED=true

# Story 8.1: conversa placeholder para leads criados manualmente (par contactId + phoneNumberId).
# Use o mesmo phone_number_id que a Meta envia em produção, ou "manual" em dev.
# MANUAL_LEAD_PHONE_NUMBER_ID=manual

# --- Frontend (Story 0.5+) ---
# VITE_API_URL=http://localhost:3000
